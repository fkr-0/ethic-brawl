{
  "name": "ethic-brawl",
  "version": "1.5.1",
  "description": "A 2.5D cyberpunk philosophical arena-brawler with absurd humor",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "imports:fix": "biome check --write --assist-enabled=true --only=assist/source/organizeImports src tests e2e",
    "format": "biome format --write .",
    "test:single": "vitest run",
    "test:simulation": "vitest run tests/unit/*runtime*.test.ts tests/unit/*system*.test.ts tests/unit/gameplay-architecture.test.ts",
    "release:check": "node scripts/release-check.mjs",
    "test:e2e:sprites": "playwright test e2e/sprite-animation.spec.ts",
    "assets:build": "python scripts/build-release-atlases.py && python scripts/build-character-extensions.py",
    "assets:check": "node scripts/check-release-assets.mjs"
  },
  "keywords": ["game", "brawler", "cyberpunk", "philosophy", "canvas"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@playwright/test": "1.60.0",
    "@types/node": "^24.13.3",
    "@vitest/ui": "^2.1.9",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  }
}
