{
  "name": "ethic-brawl",
  "version": "1.5.1",
  "description": "A 2.5D cyberpunk philosophical arena-brawler with absurd humor",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "imports:fix": "biome check --write --assist-enabled=true --only=assist/source/organizeImports src tests e2e",
    "format": "biome format --write .",
    "test:single": "vitest run",
    "test:simulation": "vitest run tests/unit/*runtime*.test.ts tests/unit/*system*.test.ts tests/unit/gameplay-architecture.test.ts",
    "release:check": "node scripts/release-check.mjs",
    "test:e2e:sprites": "playwright test e2e/sprite-animation.spec.ts",
    "test:e2e:sprite-review": "playwright test e2e/sprite-visual-review.spec.ts",
    "test:e2e:sprite-review:update": "ETHIC_SPRITE_REVIEW_DIR=generated/sprite-visual-review playwright test e2e/sprite-visual-review.spec.ts",
    "assets:build": "python3 scripts/build-character-animation-v2.py --character all && python scripts/build-release-atlases.py && python scripts/build-character-extensions.py",
    "assets:animation-v2": "python3 scripts/build-character-animation-v2.py --character all",
    "assets:animation-v2:check": "python3 scripts/build-character-animation-v2.py --character all --check",
    "assets:bakunin-v2": "python3 scripts/build-character-animation-v2.py --character bakunin",
    "assets:bakunin-v2:check": "python3 scripts/build-character-animation-v2.py --character bakunin --check",
    "assets:hegel-v2": "python3 scripts/build-character-animation-v2.py --character hegel",
    "assets:hegel-v2:check": "python3 scripts/build-character-animation-v2.py --character hegel --check",
    "assets:stirner-v2": "python3 scripts/build-character-animation-v2.py --character stirner",
    "assets:stirner-v2:check": "python3 scripts/build-character-animation-v2.py --character stirner --check",
    "assets:check": "node scripts/check-release-assets.mjs",
    "prompts:v2:generate": "python3 docs/prompts/fighter-animation-v2/render-prompts.py",
    "prompts:v2:check": "python3 docs/prompts/fighter-animation-v2/render-prompts.py --check"
  },
  "keywords": [
    "game",
    "brawler",
    "cyberpunk",
    "philosophy",
    "canvas"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@playwright/test": "1.60.0",
    "@types/node": "^24.13.3",
    "@vitest/ui": "^2.1.9",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  }
}
