{
  "name": "ethic-brawl",
  "version": "1.0.0",
  "description": "A 2.5D cyberpunk philosophical arena-brawler with absurd humor",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test:single": "vitest run",
    "test:simulation": "vitest run tests/unit/*runtime*.test.ts tests/unit/*system*.test.ts tests/unit/gameplay-architecture.test.ts",
    "release:check": "node scripts/release-check.mjs"
  },
  "keywords": ["game", "brawler", "cyberpunk", "philosophy", "canvas"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@vitest/ui": "^2.1.9",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  }
}
